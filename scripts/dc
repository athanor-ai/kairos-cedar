#!/usr/bin/env bash
# Thin wrapper: `./scripts/dc <cmd...>` → `docker compose run --rm kairos-cedar <cmd...>`.
# One image, every toolchain. `./scripts/dc lean --version`, `./scripts/dc cargo build`,
# `./scripts/dc go test ./...`, `./scripts/dc dafny --version`, etc.
set -euo pipefail

cd "$(dirname "$0")/.."
exec docker compose -f containers/compose.yaml run --rm kairos-cedar "$@"
